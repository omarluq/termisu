{
  "name": "@termisu/core",
  "version": "0.0.0",
  "description": "Bun FFI bindings for Termisu",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run clean && bun build src/index.ts --outdir dist --target bun --format esm && bun run build:types",
    "build:types": "bun run --cwd ../platform build:types && bunx tsc -p tsconfig.json --emitDeclarationOnly",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "clean": "rimraf dist",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "bun test tests",
    "typecheck": "bun run --cwd ../platform build:types && bunx tsc -p tsconfig.json --noEmit",
    "dev": "bun run examples/basic.ts"
  },
  "dependencies": {
    "@termisu/platform": "workspace:*"
  },
  "optionalDependencies": {
    "@termisu/native-darwin-arm64": "workspace:*",
    "@termisu/native-darwin-x64": "workspace:*",
    "@termisu/native-freebsd-arm64": "workspace:*",
    "@termisu/native-freebsd-x64": "workspace:*",
    "@termisu/native-linux-arm64-gnu": "workspace:*",
    "@termisu/native-linux-arm64-musl": "workspace:*",
    "@termisu/native-linux-x64-gnu": "workspace:*",
    "@termisu/native-linux-x64-musl": "workspace:*"
  },
  "keywords": [
    "termisu",
    "bun",
    "ffi",
    "tui",
    "terminal"
  ],
  "author": "Termisu Contributors",
  "license": "MIT"
}
